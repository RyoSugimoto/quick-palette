{
  "name": "quick-palette",
  "version": "0.2.1",
  "description": "Explore and generate reproducible OKLCH-based color palettes from the command line.",
  "license": "MIT",
  "author": "Ryo Sugimoto",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RyoSugimoto/quick-palette.git"
  },
  "homepage": "https://github.com/RyoSugimoto/quick-palette#readme",
  "bugs": {
    "url": "https://github.com/RyoSugimoto/quick-palette/issues"
  },
  "keywords": [
    "color",
    "palette",
    "oklch",
    "cli"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "bin": {
    "quick-palette": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test --exclude test/cli/package.test.ts && pnpm typecheck",
    "start": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:core": "vitest run test/core",
    "benchmark:tuning": "pnpm build && node dist/benchmark/perceptual-harmony.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "colorjs.io": "^0.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
